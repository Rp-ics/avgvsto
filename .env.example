# AVGVSTO Server — Environment Variables
# Copy to .env for local development.
# These override values from config/*.toml.
#
# PRODUCTION SETUP (free):
#   Database: https://supabase.com (free PostgreSQL)
#   Server:   https://fly.io (free tier)
#   Frontend: https://pages.cloudflare.com (free)
#
# 1. Create a Supabase project
# 2. Go to Project Settings → Database → Connection string (URI)
# 3. Set AVGVSTO_DATABASE__URL to that connection string
# 4. Generate a secure JWT secret: openssl rand -hex 64
# 5. Set AVGVSTO_AUTH__JWT_SECRET to that value
# 6. Deploy: fly launch (first time) then fly deploy

# Server
AVGVSTO_SERVER__HOST=0.0.0.0
AVGVSTO_SERVER__PORT=8080
AVGVSTO_SERVER__ALLOWED_ORIGINS=https://avgvstousb.com

# Database (Supabase)
# AVGVSTO_DATABASE__URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:6543/postgres

# Auth
AVGVSTO_AUTH__JWT_SECRET=change-me-to-a-secure-random-key-at-least-32-chars

# Logging
AVGVSTO_LOGGING__LEVEL=info

# Rate limiting
AVGVSTO_RATE_LIMITING__ENABLED=true
AVGVSTO_RATE_LIMITING__REQUESTS_PER_MINUTE=60
AVGVSTO_RATE_LIMITING__BURST_SIZE=10
